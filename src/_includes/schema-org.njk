{#
  Base structured data — injected in <head> via base.njk.
  Provides ProfessionalService + Person (Dr. Tabansky) on every page.
  Page-specific schemas (FAQPage, Service) are added per .njk file via a
  `page_schema` front-matter block rendered after this one.
#}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfessionalService",
      "@id": "https://www.magenvip.tech/#organization",
