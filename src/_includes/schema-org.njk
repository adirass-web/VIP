      "areaServed": [
        { "@type": "Country", "name": "Israel" }
      ],
      "availableLanguage": ["Hebrew", "English", "Russian"],
      "priceRange": "₪₪₪₪",
      "knowsAbout": [
        "Personal cybersecurity",
        "Device hardening",
        "Account security",
        "Digital counter-intelligence",
        "Divorce digital security",
        "Business dispute data protection",
        "Commercial espionage prevention"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Protection Tiers",
