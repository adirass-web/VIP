            "price": "3500",
            "priceCurrency": "ILS"
          },
          {
            "@type": "Offer",
            "name": "Personal Shield",
            "description": "One person, primary device, and all accounts. Hardware security key included.",
            "price": "15000",
            "priceCurrency": "ILS"
          },
          {
            "@type": "Offer",
            "name": "Extended Shield",
            "description": "Adds home network, vehicle systems, and all connected devices.",
            "price": "32000",
            "priceCurrency": "ILS"
          },
          {
            "@type": "Offer",
            "name": "Inner Circle Shield",
            "description": "Typically three people fully hardened.",
            "price": "38000",
            "priceCurrency": "ILS"
          },
          {
            "@type": "Offer",
            "name": "Sovereign Shield",
            "description": "Adds physical counter-surveillance and ongoing threat monitoring.",
            "price": "95000",
            "priceCurrency": "ILS"
          }
        ]
      },
      "founder": { "@id": "https://www.magenvip.tech/en/founder.html#person" },
      "employee": { "@id": "https://www.magenvip.tech/en/founder.html#person" }
    },
    {
      "@type": "Person",
      "@id": "https://www.magenvip.tech/en/founder.html#person",
      "name": "Lior Tabansky",
      "honorificPrefix": "Dr.",
      "givenName": "Lior",
      "familyName": "Tabansky",
      "jobTitle": "Personal Cybersecurity Expert",
      "description": "Two decades advising governments and intelligence agencies on cyber operations across Israel, Asia, Europe, and Africa.",
      "knowsAbout": [
        "Cybersecurity",
        "Device hardening",
        "Intelligence operations",
        "Digital counter-intelligence",
        "Personal privacy"
      ],
      "worksFor": { "@id": "https://www.magenvip.tech/#organization" },
      "url": "https://www.magenvip.tech/{{ locale }}/founder.html",
      "sameAs": []
    }
  ]
}
</script>
